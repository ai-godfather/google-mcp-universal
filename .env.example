# ============================================================
#  Google Ads Universal MCP — Environment Variables
# ============================================================
#  Copy this file to .env and fill in your values.
#  The .env file is loaded automatically by the MCP server.
#
#  HOW TO GET THESE VALUES:
#  See README_INSTALL_MCP_WINDOWS.txt, section 7
# ============================================================


# --- GOOGLE ADS API (required) ---

# Developer Token — get from Google Ads > Tools > API Center
# Looks like: AbCdEfGhIjKlMnOp
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth Client ID — create at console.cloud.google.com > Credentials
# Looks like: 123456789012-abcdefg.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_ID=

# OAuth Client Secret — from the same Credentials page
# Looks like: GOCSPX-AbCdEfGhIjKlMnOpQrSt
GOOGLE_ADS_CLIENT_SECRET=

# OAuth Refresh Token — generate via OAuth Playground or Python script
# Looks like: 1//0abCdEfGhIjKlMnOpQrStUvWxYz
GOOGLE_ADS_REFRESH_TOKEN=

# Your Google Ads Customer ID (10 digits, no dashes)
# Find at: ads.google.com — top right corner (e.g., 123-456-7890 → 1234567890)
GOOGLE_ADS_CUSTOMER_ID=

# MCC (Manager Account) ID — only if you use a manager account
# Leave empty if you manage a single account directly
GOOGLE_ADS_LOGIN_CUSTOMER_ID=


# --- MERCHANT CENTER (optional) ---

# Separate refresh token for Merchant Center API
# If empty, falls back to GOOGLE_ADS_REFRESH_TOKEN
# Needed only if your Merchant Center uses different OAuth scopes
MERCHANT_CENTER_REFRESH_TOKEN=


# --- AI AD COPY GENERATION (optional) ---

# OpenAI API Key — for AI-generated ad headlines and descriptions
# Get from: platform.openai.com/api-keys
# Without this, the plugin uses template-based ad copy (still works fine)
OPENAI_API_KEY=

# Anthropic API Key — alternative AI provider (optional)
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=


# --- PAGESPEED INSIGHTS (optional) ---

# Google PageSpeed Insights API Key
# Get from: console.cloud.google.com > APIs > PageSpeed Insights API > Credentials
# Without this, PageSpeed scans will not work
PSI_API_KEY=

# Path to local Shopify theme repositories (for PageSpeed fix commands)
# Example Windows: C:\Projects\shopify-themes
# Example Mac:     /Users/yourname/Projects/shopify-themes
REPOS_PATH=


# --- ADVANCED (optional) ---

# Path to config.json (if not in the default location)
# The plugin looks for config.json in the plugin directory by default
# Set this only if your config.json is stored elsewhere
GOOGLE_ADS_PLUGIN_CONFIG=
